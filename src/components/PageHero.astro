---
interface Props {
  overline?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}
const { overline, title, subtitle, align = 'center' } = Astro.props;
---
<section class:list={['phero grain', { 'phero--left': align === 'left' }]} style="position:relative;">
  <div class="container phero__inner">
    {overline && <p class="overline overline--light">{overline}</p>}
    <h1 set:html={title} />
    {subtitle && <p class="phero__sub">{subtitle}</p>}
    <slot />
  </div>
  <!-- Angled clip bottom -->
  <div class="phero__clip" aria-hidden="true"></div>
</section>

<style>
  .phero {
    background: var(--avo-950);
    padding: calc(72px + 72px) 0 96px;
    color: #fff; overflow: hidden; position: relative;
  }
  .phero__inner { position:relative; z-index:1; text-align:center; }
  .phero--left .phero__inner { text-align:left; }
  .phero h1 { color:#fff; max-width:820px; margin:var(--s3) auto var(--s5); }
  .phero--left h1 { margin-left:0; }
  .phero__sub { font-size:18px; color:rgba(255,255,255,.60); max-width:560px; margin:0 auto; line-height:1.65; }
  .phero--left .phero__sub { margin-left:0; }
  .phero__clip {
    position:absolute; bottom:-2px; left:0; right:0; height:56px;
    background:var(--bg-page);
    clip-path:polygon(0 100%, 100% 0, 100% 100%);
  }
  /* Decorative rings */
  .phero::before, .phero::after {
    content:''; position:absolute; border-radius:50%;
    border:1px solid rgba(255,255,255,.05); pointer-events:none;
  }
  .phero::before { width:600px; height:600px; top:-200px; right:-100px; }
  .phero::after  { width:280px; height:280px; bottom:40px; left:-60px; border-color:rgba(156,182,104,.08); }
</style>
