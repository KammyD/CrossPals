---
import Logo from './Logo.astro';
import { getLangFromUrl, useTranslations, localePath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = lang === 'en'
  ? ['Product Sourcing','Quality Inspection','Purchasing & Payment','Shipping & Logistics']
  : ['Búsqueda de Productos','Inspección de Calidad','Compra y Pago','Envío y Logística'];

const company = [
  { label: lang === 'en' ? 'About Us' : 'Sobre Nosotros', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: lang === 'en' ? 'Contact' : 'Contacto', href: '/contact' },
];
---

<footer class="footer grain" style="position:relative;">
  <div class="footer__top container">
    <div class="footer__brand">
      <Logo variant="light" size="md" />
      <p>{t('footer_tagline')}</p>
      <div class="footer__social">
        <a href="https://wa.me/yourwhatsapp" aria-label="WhatsApp" class="soc">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href="#" aria-label="LinkedIn" class="soc">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="#" aria-label="Instagram" class="soc">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      </div>
    </div>

    <div class="footer__col">
      <h5>{t('footer_services')}</h5>
      <ul>
        {services.map(s => <li><a href={localePath(lang,'/services')}>{s}</a></li>)}
      </ul>
    </div>
    <div class="footer__col">
      <h5>{t('footer_company')}</h5>
      <ul>
        {company.map(c => <li><a href={localePath(lang,c.href)}>{c.label}</a></li>)}
      </ul>
    </div>
    <div class="footer__col">
      <h5>{t('footer_legal')}</h5>
      <ul>
        <li><a href={localePath(lang,'/privacy')}>{t('footer_privacy')}</a></li>
        <li><a href={localePath(lang,'/terms')}>{t('footer_terms')}</a></li>
      </ul>
      <div class="footer__contact">
        <a href="mailto:hello@crosspals.com">hello@crosspals.com</a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bar">
    <div class="container footer__bar-inner">
      <p>© {new Date().getFullYear()} CrossPals — {t('footer_rights')}</p>
      <p class="footer__made">Connecting entrepreneurs worldwide 🌍</p>
    </div>
  </div>
</footer>

<style>
  .footer { background:var(--avo-950); color:rgba(255,255,255,0.55); overflow:hidden; }

  .footer__top {
    display:grid; grid-template-columns:2fr 1fr 1fr 1fr;
    gap:var(--s8); padding:var(--s9) 0 var(--s8);
    border-bottom:1px solid rgba(255,255,255,0.07);
  }

  .footer__brand { display:flex; flex-direction:column; gap:var(--s4); }
  .footer__brand p { font-size:13px; color:rgba(255,255,255,0.45); max-width:240px; line-height:1.6; }

  .footer__social { display:flex; gap:var(--s2); margin-top:var(--s2); }
  .soc {
    width:36px; height:36px; border-radius:50%;
    background:rgba(255,255,255,0.07); color:rgba(255,255,255,0.45);
    display:flex; align-items:center; justify-content:center;
    text-decoration:none; transition:var(--t-fast);
  }
  .soc:hover { background:var(--avo-600); color:#fff; transform:translateY(-2px); }

  .footer__col h5 {
    font-family:var(--font-mono); font-size:10px; font-weight:500;
    letter-spacing:0.12em; text-transform:uppercase;
    color:rgba(255,255,255,0.85); margin-bottom:var(--s5);
  }
  .footer__col ul { list-style:none; display:flex; flex-direction:column; gap:var(--s3); }
  .footer__col a { font-size:13px; color:rgba(255,255,255,0.45); text-decoration:none; transition:color var(--t-fast); }
  .footer__col a:hover { color:var(--avo-300); }

  .footer__contact { margin-top:var(--s5); padding-top:var(--s4); border-top:1px solid rgba(255,255,255,0.07); }

  .footer__bar { padding:var(--s4) 0 var(--s5); }
  .footer__bar-inner { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:var(--s2); }
  .footer__bar p { font-size:12px; color:rgba(255,255,255,0.25); }
  .footer__made { font-style:italic; }

  @media(max-width:900px) {
    .footer__top { grid-template-columns:1fr 1fr; gap:var(--s7); }
    .footer__brand { grid-column:1/-1; }
  }
  @media(max-width:540px) {
    .footer__top { grid-template-columns:1fr; }
    .footer__bar-inner { flex-direction:column; text-align:center; }
  }
</style>
