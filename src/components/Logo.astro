---
interface Props {
  variant?: 'dark' | 'light';
  size?: 'sm' | 'md' | 'lg';
}
const { variant = 'dark', size = 'md' } = Astro.props;
const hs = { sm: 34, md: 42, lg: 56 };
const h = hs[size];
---
<a href="/" class="logo" aria-label="CrossPals Home">
  <img
    src={variant === 'light' ? '/img/logo-light.png' : '/img/logo-dark.png'}
    alt="CrossPals"
    height={h}
  />
</a>
<style>
  .logo { display:inline-flex; align-items:center; text-decoration:none; flex-shrink:0; transition:opacity .2s; }
  .logo:hover { opacity:.85; }
</style>
