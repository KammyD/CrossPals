---
/**
 * Icon — CrossPals SVG 图标库
 * 用法: <Icon name="sourcing" class="icon-xl" />
 *
 * 所有图标均为原创 SVG 线面结合设计，替代 emoji
 */
export type IconName = 'sourcing' | 'inspection' | 'payment' | 'shipping' | 'factory' | 'reorder' | 'trust' | 'global' | 'transparent' | 'endtoend' | 'compass' | 'check-circle' | 'star' | 'package' | 'clock' | 'lock' | 'handshake';
/**
export type IconName =
  | 'sourcing'       // 产品搜索 — 放大镜+供应链
  | 'inspection'     // 质检 — 盾牌+对勾
  | 'payment'        // 采购付款 — 握手
  | 'shipping'       // 物流运输 — 货运箱+轨迹
  | 'factory'        // 工厂 — 建筑剪影
  | 'reorder'        // 重复订购 — 循环箭头
  | 'trust'          // 信任 — 双手
  | 'global'         // 全球视野 — 地球
  | 'transparent'    // 透明定价 — 眼睛
  | 'endtoend'       // 端到端 — 链条
  | 'compass'        // 使命 — 指南针
  | 'check-circle'   // 完成 — 圆圈对勾
  | 'star'           // 评分 — 星形
  | 'package'        // 包裹 — 箱子
  | 'clock'          // 时间 — 时钟
  | 'lock'           // 安全 — 锁
  | 'handshake';     // 合作 — 握手
**/
interface Props {
  name: IconName;
  class?: string;
  size?: number;
  color?: string;
}

const {
  name,
  class: cls = '',
  size = 28,
  color = 'currentColor',
} = Astro.props;

const icons: Record<IconName, string> = {

  /* ── 产品搜索 ── */
  sourcing: `
    <circle cx="11" cy="11" r="7" stroke="${color}" stroke-width="1.8" fill="none"/>
    <path d="M16.5 16.5L21 21" stroke="${color}" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M8.5 11h5M11 8.5v5" stroke="${color}" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M4 20c1-2 3-3 5-3" stroke="${color}" stroke-width="1.4" stroke-linecap="round" fill="none" opacity="0.5"/>
    <path d="M20 4c-2 1-3 3-3 5" stroke="${color}" stroke-width="1.4" stroke-linecap="round" fill="none" opacity="0.5"/>
  `,

  /* ── 质量检验 ── */
  inspection: `
    <path d="M12 2L4 6v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V6L12 2z"
      stroke="${color}" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
    <polyline points="8 12 10.5 14.5 16 9"
      stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  `,

  /* ── 付款采购 ── */
  payment: `
    <path d="M4 8h16v11a1 1 0 01-1 1H5a1 1 0 01-1-1V8z"
      stroke="${color}" stroke-width="1.8" fill="none"/>
    <path d="M4 8l2-3h12l2 3" stroke="${color}" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
    <path d="M8 13h4M8 16h2" stroke="${color}" stroke-width="1.6" stroke-linecap="round"/>
    <circle cx="16" cy="14.5" r="2.5" stroke="${color}" stroke-width="1.5" fill="none"/>
  `,

  /* ── 物流运输 ── */
  shipping: `
    <rect x="2" y="7" width="14" height="10" rx="1.5" stroke="${color}" stroke-width="1.8" fill="none"/>
    <path d="M16 10h3.5l2.5 3.5V17h-6V10z" stroke="${color}" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
    <circle cx="6.5" cy="18.5" r="2" stroke="${color}" stroke-width="1.6" fill="none"/>
    <circle cx="17.5" cy="18.5" r="2" stroke="${color}" stroke-width="1.6" fill="none"/>
    <path d="M2 12h6M2 14.5h4" stroke="${color}" stroke-width="1.4" stroke-linecap="round" opacity="0.5"/>
  `,

  /* ── 工厂 ── */
  factory: `
    <path d="M2 20V10l5-4v4l5-4v4l5-4v14H2z" stroke="${color}" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
    <rect x="9" y="14" width="3" height="6" rx="0.5" stroke="${color}" stroke-width="1.4" fill="none"/>
    <rect x="4" y="14" width="2.5" height="3" rx="0.5" stroke="${color}" stroke-width="1.4" fill="none"/>
    <rect x="14.5" y="14" width="2.5" height="3" rx="0.5" stroke="${color}" stroke-width="1.4" fill="none"/>
    <path d="M2 10h20" stroke="${color}" stroke-width="1.2" opacity="0.3"/>
    <path d="M17 6V2M19.5 4.5L14.5 4.5" stroke="${color}" stroke-width="1.4" stroke-linecap="round" opacity="0.5"/>
  `,

  /* ── 循环补货 ── */
  reorder: `
    <path d="M4 12a8 8 0 018-8 8 8 0 016.93 4" stroke="${color}" stroke-width="1.8" stroke-linecap="round" fill="none"/>
    <path d="M20 12a8 8 0 01-8 8 8 8 0 01-6.93-4" stroke="${color}" stroke-width="1.8" stroke-linecap="round" fill="none"/>
    <polyline points="18 4 21 7 18 10" stroke="${color}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <polyline points="6 20 3 17 6 14" stroke="${color}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  `,

  /* ── 信任第一 ── */
  trust: `
    <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"
      stroke="${color}" stroke-width="1.6" fill="none" opacity="0.3"/>
    <path d="M8 12c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4-4-1.8-4-4z"
      stroke="${color}" stroke-width="1.8" fill="none"/>
    <path d="M9.5 10.5l1.5 1.5 3.5-3.5" stroke="${color}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  `,

  /* ── 全球视野 ── */
  global: `
    <circle cx="12" cy="12" r="9.5" stroke="${color}" stroke-width="1.8" fill="none"/>
    <path d="M12 2.5C12 2.5 8.5 6 8.5 12s3.5 9.5 3.5 9.5"
      stroke="${color}" stroke-width="1.4" fill="none" stroke-linecap="round"/>
    <path d="M12 2.5C12 2.5 15.5 6 15.5 12s-3.5 9.5-3.5 9.5"
      stroke="${color}" stroke-width="1.4" fill="none" stroke-linecap="round"/>
    <path d="M2.5 12h19M3.5 7.5h17M3.5 16.5h17"
      stroke="${color}" stroke-width="1.2" fill="none" opacity="0.6"/>
  `,

  /* ── 透明定价 ── */
  transparent: `
    <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"
      stroke="${color}" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
    <circle cx="12" cy="12" r="3" stroke="${color}" stroke-width="1.8" fill="none"/>
    <path d="M12 9V7M12 17v-2" stroke="${color}" stroke-width="1.4" stroke-linecap="round" opacity="0.5"/>
  `,

  /* ── 端到端服务 ── */
  endtoend: `
    <circle cx="5" cy="12" r="3" stroke="${color}" stroke-width="1.8" fill="none"/>
    <circle cx="19" cy="12" r="3" stroke="${color}" stroke-width="1.8" fill="none"/>
    <path d="M8 12h8" stroke="${color}" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M12 8l2 4-2 4" stroke="${color}" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.5"/>
  `,

  /* ── 指南针/使命 ── */
  compass: `
    <circle cx="12" cy="12" r="9.5" stroke="${color}" stroke-width="1.8" fill="none"/>
    <path d="M16.5 7.5l-3 6-6 3 3-6 6-3z"
      stroke="${color}" stroke-width="1.6" fill="none" stroke-linejoin="round"/>
    <circle cx="12" cy="12" r="1.5" fill="${color}"/>
    <path d="M12 2.5v1.5M12 20v1.5M2.5 12H4M20 12h1.5"
      stroke="${color}" stroke-width="1.4" stroke-linecap="round" opacity="0.4"/>
  `,

  /* ── 完成对勾 ── */
  'check-circle': `
    <circle cx="12" cy="12" r="9.5" stroke="${color}" stroke-width="1.8" fill="none"/>
    <polyline points="7.5 12 10.5 15 16.5 9"
      stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  `,

  /* ── 星形评分 ── */
  star: `
    <path d="M12 2l2.9 5.9L21 9l-4.5 4.4L17.8 20 12 17l-5.8 3 1.3-6.6L3 9l6.1-1.1L12 2z"
      stroke="${color}" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
  `,

  /* ── 包裹箱子 ── */
  package: `
    <path d="M21 8L12 3 3 8v8l9 5 9-5V8z"
      stroke="${color}" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
    <path d="M12 3v13M3 8l9 5 9-5"
      stroke="${color}" stroke-width="1.4" fill="none" opacity="0.6"/>
    <path d="M7.5 5.5L16.5 10.5" stroke="${color}" stroke-width="1.4" stroke-linecap="round" opacity="0.4"/>
  `,

  /* ── 时钟 ── */
  clock: `
    <circle cx="12" cy="12" r="9.5" stroke="${color}" stroke-width="1.8" fill="none"/>
    <path d="M12 7v5l3 3" stroke="${color}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  `,

  /* ── 锁/安全 ── */
  lock: `
    <rect x="5" y="11" width="14" height="10" rx="2" stroke="${color}" stroke-width="1.8" fill="none"/>
    <path d="M8 11V7a4 4 0 018 0v4" stroke="${color}" stroke-width="1.8" fill="none" stroke-linecap="round"/>
    <circle cx="12" cy="16" r="1.5" fill="${color}"/>
    <path d="M12 16v2" stroke="${color}" stroke-width="1.6" stroke-linecap="round"/>
  `,

  /* ── 握手合作 ── */
  handshake: `
    <path d="M2 13l4-4 3 1 4-4 5 2" stroke="${color}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <path d="M9 10l2 2-3 3-2-2 3-3z" stroke="${color}" stroke-width="1.6" fill="none" stroke-linejoin="round"/>
    <path d="M13 8l4 4-2 2-4-4 2-2z" stroke="${color}" stroke-width="1.6" fill="none" stroke-linejoin="round"/>
    <path d="M6 16l2 2M16 8l2-2" stroke="${color}" stroke-width="1.4" stroke-linecap="round" opacity="0.5"/>
  `,
};
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  class:list={['icon-svg', cls]}
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
  set:html={icons[name]}
/>
