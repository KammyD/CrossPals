---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ImgPlaceholder from '../../components/ImgPlaceholder.astro';

const posts = [
  { slug:'find-suppliers-1688',    title:'How to Find Reliable Suppliers on 1688 Without Speaking Chinese', excerpt:'A step-by-step guide to China\'s largest B2B platform — screenshots, template messages, and search tricks included.', cat:'Sourcing Guide', time:'5 min', date:'2024-11-12', featured:true,  seed:501, hint:'建议：1688网站界面 / 义乌商品城' },
  { slug:'air-vs-sea-freight',     title:'Air vs Sea Freight: Which Should You Choose for Your First Order?', excerpt:'Cost-benefit breakdown for first-time importers. When speed matters more than savings.', cat:'Shipping',      time:'4 min', date:'2024-10-28', seed:502, hint:'建议：货运飞机 / 集装箱码头' },
  { slug:'cheap-china-products',   title:'5 Products That Are Cheaper in China and Sell Well Everywhere', excerpt:'Practical product categories with proven margins across Africa, Latin America, and Southeast Asia.', cat:'Business Tips', time:'6 min', date:'2024-10-05', seed:503, hint:'建议：热销商品 / 产品陈列' },
  { slug:'avoid-alibaba-scams',    title:'How to Avoid the 7 Most Common Alibaba Scams', excerpt:'Protect your money by learning the red flags that experienced importers always watch for.', cat:'Safety',       time:'7 min', date:'2024-09-20', seed:504, hint:'建议：警示/安全/合同场景' },
  { slug:'custom-packaging-guide', title:'Custom Packaging from China: A Beginner\'s Complete Guide', excerpt:'Your logo on boxes, bags, and labels — MOQs, lead times, costs, and what to watch out for.', cat:'Branding',     time:'5 min', date:'2024-09-08', seed:505, hint:'建议：定制包装盒 / 品牌印刷' },
  { slug:'payment-methods-suppliers', title:'The Safest Ways to Pay Chinese Suppliers', excerpt:'From Alibaba Trade Assurance to wire transfers — how to protect your money on every order.', cat:'Payments',     time:'4 min', date:'2024-08-22', seed:506, hint:'建议：网上支付 / 银行转账场景' },
];

const featured = posts.find(p => p.featured)!;
const rest = posts.filter(p => !p.featured);
const cats = ['All', ...Array.from(new Set(posts.map(p => p.cat)))];
---
<BaseLayout title="Blog" description="Practical guides for global entrepreneurs sourcing from China.">

  <PageHero overline="Resources" title="The Sourcing<br /><em style='font-style:italic;color:var(--avo-300)'>Knowledge Base</em>" subtitle="Practical guides for global entrepreneurs importing from China." />

  <section class="section">
    <div class="container">

      <!-- Featured with large cover image -->
      <a href={`/blog/${featured.slug}`} class="featured reveal">
        {/* 📸 SLOT I: 精选文章封面图 — 建议：宽幅横向，与文章主题高度相关 */}
        <div class="featured__img">
          <ImgPlaceholder seed={featured.seed} width={1200} height={560} ratio="16/7" alt={featured.title} hint={featured.hint ?? ''} />
        </div>
        <div class="featured__body">
          <div class="featured__tags">
            <span class="tag tag-green">Featured</span>
            <span class="featured__cat">{featured.cat}</span>
          </div>
          <h2>{featured.title}</h2>
          <p>{featured.excerpt}</p>
          <div class="featured__meta">
            <time>{new Date(featured.date).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}</time>
            <span>· {featured.time} read</span>
            <span class="featured__read">Read article →</span>
          </div>
        </div>
      </a>

      <!-- Filter -->
      <div class="cat-bar" id="catBar">
        {cats.map(c => (
          <button class:list={['cat-btn', {'cat-btn--on': c === 'All'}]} data-cat={c}>{c}</button>
        ))}
      </div>

      <!-- Post grid with cover images -->
      <div class="posts" id="postsGrid">
        {rest.map((post,i) => (
          <a href={`/blog/${post.slug}`} class:list={['pcard reveal', `reveal-delay-${i % 3}`]} data-cat={post.cat}>
            {/* 📸 SLOT J–N: 文章封面图 — 16:9横向，与文章主题相关 */}
            <ImgPlaceholder seed={post.seed} width={600} height={338} ratio="16/9" alt={post.title} hint={post.hint} />
            <div class="pcard__body">
              <span class="pcard__cat">{post.cat}</span>
              <h4>{post.title}</h4>
              <p>{post.excerpt}</p>
              <div class="pcard__foot">
                <time>{new Date(post.date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</time>
                <span>{post.time} read →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section bg-parchment">
    <div class="container nl-wrap">
      <div class="reveal">
        <p class="overline">Stay Updated</p>
        <h2>Sourcing tips<br /><em>in your inbox</em></h2>
        <p>Guides, supplier lists, and import tricks — once or twice a month.</p>
      </div>
      <form class="nl-form reveal reveal-delay-2" onsubmit="return false">
        <input type="email" placeholder="your@email.com" required />
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('cat-btn--on'));
      btn.classList.add('cat-btn--on');
      const cat = btn.dataset.cat!;
      document.querySelectorAll<HTMLElement>('.pcard').forEach(c => {
        c.style.display = (cat === 'All' || c.dataset.cat === cat) ? '' : 'none';
      });
    });
  });
</script>

<style>
  h2 em{font-style:italic;color:var(--avo-600);}
  /* Featured */
  .featured{display:flex;flex-direction:column;background:#fff;border:1px solid var(--warm-200);border-radius:var(--r4);overflow:hidden;text-decoration:none;color:inherit;margin-bottom:var(--s8);transition:var(--t-med);}
  .featured:hover{box-shadow:var(--shadow-lg);transform:translateY(-2px);}
  .featured__img :global(.img-ph){border-radius:0;}
  .featured__img :global(.img-ph__wrap){border-radius:0;}
  .featured__body{padding:var(--s6) var(--s7);}
  .featured__tags{display:flex;align-items:center;gap:var(--s3);margin-bottom:var(--s4);}
  .featured__cat{font-family:var(--font-mono);font-size:10px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:var(--avo-600);}
  .featured__body h2{font-size:clamp(20px,2.5vw,28px);margin-bottom:var(--s3);}
  .featured__body>p{font-size:15px;color:var(--text-body);max-width:680px;margin-bottom:var(--s5);}
  .featured__meta{display:flex;align-items:center;gap:var(--s3);font-size:12px;color:var(--warm-400);font-family:var(--font-mono);}
  .featured__read{margin-left:auto;color:var(--avo-600);font-weight:600;}
  /* Filter */
  .cat-bar{display:flex;flex-wrap:wrap;gap:var(--s2);margin-bottom:var(--s6);}
  .cat-btn{background:#fff;border:1.5px solid var(--warm-200);color:var(--text-body);padding:7px 18px;border-radius:var(--rfull);font-size:13px;font-weight:500;cursor:pointer;transition:var(--t-fast);font-family:var(--font-sans);}
  .cat-btn:hover,.cat-btn--on{background:var(--avo-700);border-color:var(--avo-700);color:#fff;}
  /* Grid */
  .posts{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--s5);}
  .pcard{background:#fff;border:1px solid var(--warm-200);border-radius:var(--r3);display:flex;flex-direction:column;text-decoration:none;color:inherit;transition:var(--t-med);overflow:hidden;}
  .pcard:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:var(--avo-200);}
  .pcard :global(.img-ph){border-radius:0;flex-shrink:0;}
  .pcard :global(.img-ph__wrap){border-radius:0;}
  .pcard__body{padding:var(--s5);display:flex;flex-direction:column;gap:var(--s3);flex:1;}
  .pcard__cat{font-family:var(--font-mono);font-size:10px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:var(--avo-600);}
  .pcard h4{font-size:17px;line-height:1.3;transition:color var(--t-fast);}
  .pcard:hover h4{color:var(--avo-700);}
  .pcard>p,.pcard__body>p{font-size:13px;color:var(--text-body);line-height:1.7;flex:1;}
  .pcard__foot{display:flex;justify-content:space-between;align-items:center;font-size:11px;color:var(--warm-400);font-family:var(--font-mono);padding-top:var(--s4);border-top:1px solid var(--warm-100);margin-top:auto;}
  /* Newsletter */
  .nl-wrap{display:flex;align-items:center;justify-content:space-between;gap:var(--s7);flex-wrap:wrap;}
  .nl-wrap h2{margin:var(--s3) 0 var(--s4);}.nl-wrap p{font-size:15px;max-width:360px;}
  .nl-form{display:flex;gap:var(--s3);flex-shrink:0;}
  .nl-form input{padding:12px 18px;border:1.5px solid var(--warm-200);border-radius:var(--r2);font-size:15px;font-family:var(--font-sans);background:#fff;color:var(--warm-950);outline:none;transition:var(--t-fast);width:240px;}
  .nl-form input:focus{border-color:var(--avo-600);}
  @media(max-width:900px){.posts{grid-template-columns:repeat(2,1fr)}.nl-wrap{flex-direction:column;text-align:center}.nl-form{width:100%;justify-content:center}.nl-form input{flex:1;min-width:0}}
  @media(max-width:560px){.posts{grid-template-columns:1fr}}
</style>
